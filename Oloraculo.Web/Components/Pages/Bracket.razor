@page "/bracket"
@rendermode InteractiveServer
@inject KnockoutBracketService BracketService
@inject SnapshotService Snapshots
@inject EvaluationService Evaluation
@inject OloraculoDbContext Db
@inject ISnackbar Snackbar

<PageTitle>Cuadro</PageTitle>

<MudStack Spacing="3">
    <div class="page-head">
        <MudText Typo="Typo.h3">Cuadro</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary">Predicciones del cuadro de eliminación directa desde 16avos hasta la final.</MudText>
    </div>

    <MudPaper Class="surface-card" Elevation="0">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="action-row fixture-action-row">
            <BusyButton Text="Actualizar cuadro"
                        BusyText="Actualizando"
                        IsBusy="_building"
                        Disabled="@(_saving || _loadingSnapshot || _evaluating)"
                        Icon="@Icons.Material.Filled.AccountTree"
                        OnClick="BuildCurrent" />
            <BusyButton Text="Guardar snapshot"
                        BusyText="Guardando"
                        IsBusy="_saving"
                        Disabled="@(!CanSaveBracket || _building || _loadingSnapshot || _evaluating)"
                        Variant="Variant.Outlined"
                        Icon="@Icons.Material.Filled.Save"
                        OnClick="SaveSnapshot" />
            <MudSelect T="int"
                       Dense="true"
                       Variant="Variant.Outlined"
                       Class="snapshot-select"
                       Disabled="@(!_snapshotsLoaded || _snapshots.Count == 0 || _building || _saving || _loadingSnapshot || _evaluating)"
                       @bind-Value="_selectedSnapshotId">
                @foreach (var snapshot in _snapshots)
                {
                    <MudSelectItem T="int" Value="@snapshot.Id" Disabled="@(!snapshot.IsValid)">@SnapshotText(snapshot)</MudSelectItem>
                }
            </MudSelect>
            <BusyButton Text="Cargar snapshot"
                        BusyText="Cargando"
                        IsBusy="_loadingSnapshot"
                        Disabled="@(_selectedSnapshotId == 0 || _building || _saving || _evaluating)"
                        Variant="Variant.Outlined"
                        Color="Color.Secondary"
                        Icon="@Icons.Material.Filled.History"
                        OnClick="LoadSelectedSnapshot" />
            <MudTooltip Text="Actualizar snapshots">
                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                               Color="Color.Secondary"
                               Disabled="@(_building || _saving || _loadingSnapshot || _evaluating)"
                               OnClick="RefreshSnapshots" />
            </MudTooltip>
            <MudSpacer />
            <MudText Typo="Typo.body2" Color="Color.Secondary">@StatusText</MudText>
        </MudStack>
        @if (_building || _saving || _loadingSnapshot || _evaluating)
        {
            <MudProgressLinear Class="inline-progress" Color="Color.Primary" Indeterminate="true" />
        }
    </MudPaper>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_error</MudAlert>
    }

    @if (_projection is null)
    {
        <MudGrid Spacing="2">
            @for (var i = 0; i < 5; i++)
            {
                <MudItem xs="12" md="6" xl="3">
                    <MudPaper Class="surface-card" Elevation="0">
                        <MudSkeleton Height="28px" Width="45%" />
                        <MudSkeleton Height="90px" Class="skeleton-row" />
                        <MudSkeleton Height="90px" Class="skeleton-row" />
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }
    else
    {
        <div class="bracket-board">
            @foreach (var stage in StageGroups())
            {
                <section class="bracket-stage">
                    <MudText Typo="Typo.h6">@stage.Key</MudText>
                    <div class="bracket-card-list">
                        @foreach (var tie in stage.OrderBy(t => t.TieId))
                        {
                            <MudPaper Class="bracket-match-card" Elevation="0">
                                <div class="bracket-match-meta">
                                    <span>@tie.TieId</span>
                                    <span>@tie.HomeSlotLabel vs @tie.AwaySlotLabel</span>
                                </div>
                                <div class="bracket-match-line">
                                    <div class="fixture-team">
                                        @TeamOrSlot(tie.HomeTeamId, tie.HomeSlotLabel)
                                    </div>
                                    <div class="fixture-score-slot">@ScoreText(tie)</div>
                                    <div class="fixture-team fixture-team-away">
                                        @TeamOrSlot(tie.AwayTeamId, tie.AwaySlotLabel)
                                    </div>
                                </div>
                                @if (tie.HomeAdvanceProbability.HasValue && tie.AwayAdvanceProbability.HasValue)
                                {
                                    <div class="fixture-prob-mini" title="@OddsLabel(tie)">
                                        <span class="fixture-prob-segment home" style="@SegmentStyle(tie.HomeAdvanceProbability.Value)"></span>
                                        <span class="fixture-prob-segment away" style="@SegmentStyle(tie.AwayAdvanceProbability.Value)"></span>
                                    </div>
                                    <div class="bracket-pick-row">
                                        <span>@PickText(tie)</span>
                                        <span>@tie.HomeAdvanceProbability.Value.ToString("P0") / @tie.AwayAdvanceProbability.Value.ToString("P0")</span>
                                    </div>
                                }
                                else if (!string.IsNullOrWhiteSpace(tie.Error))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@tie.Error</MudText>
                                }

                                @if (CanEnterResult(tie))
                                {
                                    <div class="bracket-result-entry">
                                        <MudNumericField T="int?"
                                                         Value="@GoalValue(_homeGoals, tie)"
                                                         ValueChanged="@((int? value) => SetGoal(_homeGoals, tie.TieId, value))"
                                                         Min="0"
                                                         Variant="Variant.Outlined"
                                                         Class="bracket-goal-input" />
                                        <span class="score-separator">-</span>
                                        <MudNumericField T="int?"
                                                         Value="@GoalValue(_awayGoals, tie)"
                                                         ValueChanged="@((int? value) => SetGoal(_awayGoals, tie.TieId, value))"
                                                         Min="0"
                                                         Variant="Variant.Outlined"
                                                         Class="bracket-goal-input" />
                                        @if (NeedsWinner(tie))
                                        {
                                            <MudSelect T="string"
                                                       Value="@WinnerValue(tie)"
                                                       ValueChanged="@((string value) => SetWinner(tie.TieId, value))"
                                                       Dense="true"
                                                       Variant="Variant.Outlined"
                                                       Class="bracket-winner-select">
                                                <MudSelectItem T="string" Value="@(tie.HomeTeamId ?? "")">@Name(tie.HomeTeamId!)</MudSelectItem>
                                                <MudSelectItem T="string" Value="@(tie.AwayTeamId ?? "")">@Name(tie.AwayTeamId!)</MudSelectItem>
                                            </MudSelect>
                                        }
                                        <MudTooltip Text="@EvaluateTooltip(tie)">
                                            <MudButton Size="Size.Small"
                                                       Variant="Variant.Outlined"
                                                       Color="Color.Primary"
                                                       StartIcon="@Icons.Material.Filled.FactCheck"
                                                       Disabled="@(!CanEvaluate(tie) || _evaluating)"
                                                       OnClick="@(() => EvaluateTie(tie))">
                                                Evaluar
                                            </MudButton>
                                        </MudTooltip>
                                    </div>
                                }
                            </MudPaper>
                        }
                    </div>
                </section>
            }
        </div>
    }
</MudStack>

@code {
    private BracketProjection? _projection;
    private IReadOnlyList<BracketSnapshotSummary> _snapshots = [];
    private Dictionary<string, string> _names = [];
    private readonly Dictionary<int, int?> _homeGoals = [];
    private readonly Dictionary<int, int?> _awayGoals = [];
    private readonly Dictionary<int, string> _winnerTeamIds = [];
    private bool _building;
    private bool _saving;
    private bool _loadingSnapshot;
    private bool _snapshotsLoaded;
    private bool _evaluating;
    private int _selectedSnapshotId;
    private int? _activeSnapshotId;
    private DateTimeOffset? _projectionTime;
    private string _error = "";

    protected override async Task OnInitializedAsync()
    {
        _names = await Db.Teams.AsNoTracking().ToDictionaryAsync(t => t.Id, t => t.Name);
        await RefreshSnapshots();

        var latest = _snapshots.FirstOrDefault(snapshot => snapshot.IsValid);
        if (latest is not null)
            await LoadSnapshot(latest, showSnackbar: false);
        else
            await BuildCurrent();
    }

    private async Task BuildCurrent()
    {
        _building = true;
        _error = "";
        try
        {
            _projection = await BracketService.BuildAsync(upsertFixtures: true);
            _projectionTime = _projection.GeneratedAt.ToLocalTime();
            _activeSnapshotId = null;
            SeedResultInputs();
            Snackbar.Add("Cuadro actualizado.", Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add("No se pudo actualizar el cuadro.", Severity.Error);
        }
        finally
        {
            _building = false;
        }
    }

    private async Task SaveSnapshot()
    {
        if (!CanSaveBracket || _projection is null)
            return;

        _saving = true;
        _error = "";
        try
        {
            var snapshot = await Snapshots.SaveBracketAsync(_projection);
            _activeSnapshotId = snapshot.Id;
            await RefreshSnapshots();
            _selectedSnapshotId = snapshot.Id;
            Snackbar.Add("Snapshot de cuadro guardado.", Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add("No se pudo guardar el snapshot de cuadro.", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task RefreshSnapshots()
    {
        _snapshotsLoaded = false;
        try
        {
            _snapshots = await Snapshots.BracketSnapshotsAsync();
            if (_selectedSnapshotId == 0 && _snapshots.FirstOrDefault(snapshot => snapshot.IsValid) is { } latest)
                _selectedSnapshotId = latest.Id;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add("No se pudieron cargar los snapshots de cuadro.", Severity.Error);
        }
        finally
        {
            _snapshotsLoaded = true;
        }
    }

    private async Task LoadSelectedSnapshot()
    {
        var snapshot = _snapshots.FirstOrDefault(s => s.Id == _selectedSnapshotId);
        if (snapshot is null)
            return;

        await LoadSnapshot(snapshot, showSnackbar: true);
    }

    private async Task LoadSnapshot(BracketSnapshotSummary snapshot, bool showSnackbar)
    {
        if (!snapshot.IsValid)
        {
            Snackbar.Add(snapshot.Error ?? "El snapshot no está disponible.", Severity.Warning);
            return;
        }

        _loadingSnapshot = true;
        _error = "";
        try
        {
            var result = await Snapshots.LoadBracketSnapshotAsync(snapshot.Id);
            if (!result.IsValid || result.Projection is null)
            {
                _error = result.Error ?? "No se pudo leer el snapshot.";
                Snackbar.Add(_error, Severity.Error);
                return;
            }

            _projection = result.Projection;
            _projectionTime = snapshot.CreatedAt.ToLocalTime();
            _activeSnapshotId = snapshot.Id;
            SeedResultInputs();
            if (showSnackbar)
                Snackbar.Add("Snapshot de cuadro cargado.", Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add("No se pudo cargar el snapshot de cuadro.", Severity.Error);
        }
        finally
        {
            _loadingSnapshot = false;
        }
    }

    private async Task EvaluateTie(BracketTieProjection tie)
    {
        if (!CanEvaluate(tie))
            return;

        var fixture = await Db.Fixtures.FirstOrDefaultAsync(f => f.Id == tie.FixtureId);
        if (fixture is null)
        {
            Snackbar.Add("No se encontró el fixture del cruce.", Severity.Error);
            return;
        }

        var homeGoals = GoalValue(_homeGoals, tie)!.Value;
        var awayGoals = GoalValue(_awayGoals, tie)!.Value;
        var winnerTeamId = homeGoals == awayGoals
            ? WinnerValue(tie)
            : homeGoals > awayGoals ? tie.HomeTeamId : tie.AwayTeamId;

        _evaluating = true;
        _error = "";
        try
        {
            var count = await Evaluation.EvaluateLatestSnapshotAsync(fixture, homeGoals, awayGoals, winnerTeamId);
            Snackbar.Add(count == 0 ? "No se encontró un snapshot para evaluar." : "Resultado guardado y snapshot evaluado.", count == 0 ? Severity.Warning : Severity.Success);
            await BuildCurrent();
            await RefreshSnapshots();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add("No se pudo evaluar el cruce.", Severity.Error);
        }
        finally
        {
            _evaluating = false;
        }
    }

    private IEnumerable<IGrouping<string, BracketTieProjection>> StageGroups() =>
        (_projection?.Ties ?? [])
            .GroupBy(tie => tie.StageLabel)
            .OrderBy(group => StageSort(group.Key));

    private void SeedResultInputs()
    {
        _homeGoals.Clear();
        _awayGoals.Clear();
        _winnerTeamIds.Clear();
        if (_projection is null)
            return;

        foreach (var tie in _projection.Ties)
        {
            _homeGoals[tie.TieId] = tie.ActualHomeGoals;
            _awayGoals[tie.TieId] = tie.ActualAwayGoals;
            if (!string.IsNullOrWhiteSpace(tie.ActualWinnerTeamId))
                _winnerTeamIds[tie.TieId] = tie.ActualWinnerTeamId;
        }
    }

    private bool CanSaveBracket =>
        _projection is not null &&
        _projection.Ties.Any(tie => tie.Prediction is not null) &&
        _activeSnapshotId is null;

    private bool CanEnterResult(BracketTieProjection tie) =>
        !string.IsNullOrWhiteSpace(tie.HomeTeamId) && !string.IsNullOrWhiteSpace(tie.AwayTeamId);

    private bool NeedsWinner(BracketTieProjection tie) =>
        GoalValue(_homeGoals, tie).HasValue &&
        GoalValue(_awayGoals, tie).HasValue &&
        GoalValue(_homeGoals, tie) == GoalValue(_awayGoals, tie);

    private bool CanEvaluate(BracketTieProjection tie)
    {
        if (!tie.LatestSnapshotId.HasValue || !CanEnterResult(tie))
            return false;

        var home = GoalValue(_homeGoals, tie);
        var away = GoalValue(_awayGoals, tie);
        if (!home.HasValue || !away.HasValue)
            return false;

        return home != away || !string.IsNullOrWhiteSpace(WinnerValue(tie));
    }

    private string EvaluateTooltip(BracketTieProjection tie)
    {
        if (!tie.LatestSnapshotId.HasValue)
            return "Guardá un snapshot del cuadro antes de evaluar este cruce.";
        if (!CanEnterResult(tie))
            return "El cruce todavía no tiene equipos.";
        if (!GoalValue(_homeGoals, tie).HasValue || !GoalValue(_awayGoals, tie).HasValue)
            return "Ingresá el resultado.";
        if (NeedsWinner(tie) && string.IsNullOrWhiteSpace(WinnerValue(tie)))
            return "Elegí quién avanza.";
        return "Guardar resultado y evaluar snapshot.";
    }

    private int? GoalValue(Dictionary<int, int?> goals, BracketTieProjection tie) =>
        goals.TryGetValue(tie.TieId, out var value) ? value : null;

    private void SetGoal(Dictionary<int, int?> goals, int tieId, int? value) =>
        goals[tieId] = value;

    private string WinnerValue(BracketTieProjection tie) =>
        _winnerTeamIds.TryGetValue(tie.TieId, out var value) ? value : "";

    private void SetWinner(int tieId, string value) =>
        _winnerTeamIds[tieId] = value;

    private string Name(string id) => _names.TryGetValue(id, out var name) ? name : id;

    private RenderFragment TeamOrSlot(string? teamId, string slot) => builder =>
    {
        if (string.IsNullOrWhiteSpace(teamId))
        {
            builder.AddContent(0, slot);
            return;
        }

        builder.OpenComponent<TeamLabel>(0);
        builder.AddAttribute(1, "TeamId", teamId);
        builder.AddAttribute(2, "Name", Name(teamId));
        builder.CloseComponent();
    };

    private string ScoreText(BracketTieProjection tie)
    {
        if (tie.IsPlayed && tie.ActualHomeGoals.HasValue && tie.ActualAwayGoals.HasValue)
            return $"{tie.ActualHomeGoals}-{tie.ActualAwayGoals}";
        if (tie.PredictedHomeGoals.HasValue && tie.PredictedAwayGoals.HasValue)
            return $"{tie.PredictedHomeGoals}-{tie.PredictedAwayGoals}";
        return "-";
    }

    private string PickText(BracketTieProjection tie) =>
        string.IsNullOrWhiteSpace(tie.PredictedWinnerTeamId)
            ? "Sin pick"
            : $"{Name(tie.PredictedWinnerTeamId)}";

    private string OddsLabel(BracketTieProjection tie)
    {
        if (tie.HomeTeamId is null || tie.AwayTeamId is null || !tie.HomeAdvanceProbability.HasValue || !tie.AwayAdvanceProbability.HasValue)
            return "";

        return $"{Name(tie.HomeTeamId)} {tie.HomeAdvanceProbability.Value:P0}, {Name(tie.AwayTeamId)} {tie.AwayAdvanceProbability.Value:P0}";
    }

    private string StatusText => _projection switch
    {
        not null when _activeSnapshotId is not null && _projectionTime.HasValue => $"{_projection.Ties.Count} cruces cargados {_projectionTime.Value:g}",
        not null when _projectionTime.HasValue => $"{_projection.Ties.Count} cruces actualizados {_projectionTime.Value:t}",
        _ => "Cargando cuadro"
    };

    private static string SegmentStyle(double value) => $"width:{Math.Max(value * 100, 0):0.###}%";

    private static string SnapshotText(BracketSnapshotSummary snapshot)
    {
        var status = snapshot.IsValid ? $"{snapshot.TieCount ?? 0} cruces" : "no disponible";
        return $"{snapshot.CreatedAt.ToLocalTime():g} · {status}";
    }

    private static int StageSort(string stage) => stage switch
    {
        "16avos" => 0,
        "Octavos" => 1,
        "Cuartos" => 2,
        "Semis" => 3,
        "Final" => 4,
        _ => 99
    };
}
