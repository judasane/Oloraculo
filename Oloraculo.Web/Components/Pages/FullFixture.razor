@page "/fixture"
@rendermode InteractiveServer
@inject OloraculoDbContext Db
@inject PredictionService Predictor
@inject SnapshotService Snapshots
@inject SimulationService Sim
@inject ISnackbar Snackbar
@using Oloraculo.Web.Services.Simulation

<PageTitle>Fixture completo</PageTitle>

<MudStack Spacing="3">
    <div class="page-head">
        <MudText Typo="Typo.h3">Fixture completo</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary">Predicción masiva de todos los partidos de la fase de grupos.</MudText>
    </div>

    <MudTabs Rounded="true" Border="false" ApplyEffectsToContainer="true" Class="fixture-tabs">
    <MudTabPanel Text="Predicción de partidos" Icon="@Icons.Material.Filled.Insights">

    <MudPaper Class="surface-card" Elevation="0">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="action-row fixture-action-row">
            <BusyButton Text="Predecir fixture completo"
                        BusyText="Prediciendo fixture"
                        IsBusy="_predicting"
                        Disabled="@(!_loaded || _fixtures.Count == 0 || _saving)"
                        Icon="@Icons.Material.Filled.AutoAwesome"
                        OnClick="PredictAll" />
            <BusyButton Text="Guardar snapshots"
                        BusyText="Guardando snapshots"
                        IsBusy="_saving"
                        Disabled="@(!CanSaveFullFixture || _predicting || _loadingSnapshot)"
                        Variant="Variant.Outlined"
                        Icon="@Icons.Material.Filled.Save"
                        OnClick="SaveAll" />
            <MudSelect T="int"
                       Dense="true"
                       Variant="Variant.Outlined"
                       Class="snapshot-select"
                       Disabled="@(!_snapshotsLoaded || _fullFixtureSnapshots.Count == 0 || _predicting || _saving || _loadingSnapshot)"
                       @bind-Value="_selectedFullFixtureSnapshotId">
                @foreach (var snapshot in _fullFixtureSnapshots)
                {
                    <MudSelectItem T="int" Value="@snapshot.Id" Disabled="@(!snapshot.IsValid)">@FullFixtureSnapshotText(snapshot)</MudSelectItem>
                }
            </MudSelect>
            <BusyButton Text="Cargar snapshot"
                        BusyText="Cargando"
                        IsBusy="_loadingSnapshot"
                        Disabled="@(_selectedFullFixtureSnapshotId == 0 || _predicting || _saving)"
                        Variant="Variant.Outlined"
                        Color="Color.Secondary"
                        Icon="@Icons.Material.Filled.History"
                        OnClick="LoadSelectedFullFixtureSnapshot" />
            <MudTooltip Text="Actualizar snapshots">
                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                               Color="Color.Secondary"
                               Disabled="@(_predicting || _saving || _loadingSnapshot)"
                               OnClick="RefreshFullFixtureSnapshots" />
            </MudTooltip>
            <MudSpacer />
            <MudText Typo="Typo.body2" Color="Color.Secondary">@StatusText</MudText>
        </MudStack>
        @if (_predicting || _saving || _loadingSnapshot)
        {
            <MudProgressLinear Class="inline-progress" Color="Color.Primary" Indeterminate="true" />
        }
    </MudPaper>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_error</MudAlert>
    }

    @if (_predictionErrors.Count > 0)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
            @_predictionErrors.Count partido(s) no pudieron predecirse. Los demás resultados disponibles se mantienen en la grilla.
        </MudAlert>
    }

    @if (!_loaded)
    {
        <MudGrid Spacing="2">
            @for (var i = 0; i < 6; i++)
            {
                <MudItem xs="12" md="6" xl="4">
                    <MudPaper Class="surface-card fixture-group-card" Elevation="0">
                        <MudSkeleton Height="28px" Width="35%" />
                        <MudSkeleton Height="54px" Class="skeleton-row" />
                        <MudSkeleton Height="54px" Class="skeleton-row" />
                        <MudSkeleton Height="54px" Class="skeleton-row" />
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }
    else if (_fixtures.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No hay partidos de grupo cargados todavía.</MudAlert>
    }
    else
    {
        <div class="fixture-legend">
            <span class="fixture-legend-item"><span class="fixture-legend-dot is-played"></span>Jugado (con resultado cargado)</span>
            <span class="fixture-legend-item"><span class="fixture-legend-dot is-predicted"></span>Predicho (sin jugar)</span>
            <span class="fixture-legend-item"><span class="fixture-legend-dot is-pending"></span>Pendiente</span>
        </div>
        <div class="fixture-board">
            @foreach (var group in GroupedFixtures())
            {
                <MudPaper Class="surface-card fixture-group-card" Elevation="0">
                    <div class="fixture-group-head">
                        <MudText Typo="Typo.h6">Grupo @group.Key</MudText>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary">@group.Count() partidos</MudChip>
                    </div>

                    <div class="fixture-card-list">
                        @foreach (var fixture in OrderedFixtures(group))
                        {
                            var hasPrediction = _predictions.TryGetValue(fixture.Id, out var prediction);
                            var hasError = _predictionErrors.TryGetValue(fixture.Id, out var predictionError);

                            <div class="fixture-match-card @CardStateClass(fixture, hasPrediction)">
                                <div class="fixture-match-meta">
                                    <span>@DateText(fixture)</span>
                                    @if (fixture.IsPlayed && fixture.HomeGoals.HasValue && fixture.AwayGoals.HasValue)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">Jugado</MudChip>
                                    }
                                    else if (hasPrediction)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">Predicho</MudChip>
                                    }
                                </div>

                                <div class="fixture-match-line">
                                    <div class="fixture-team fixture-team-home">
                                        <TeamLabel TeamId="@fixture.HomeTeamId" Name="@Name(fixture.HomeTeamId)" Compact="true" />
                                    </div>
                                    <div class="fixture-score-slot">@ScoreText(fixture, prediction)</div>
                                    <div class="fixture-team fixture-team-away">
                                        <TeamLabel TeamId="@fixture.AwayTeamId" Name="@Name(fixture.AwayTeamId)" Compact="true" />
                                    </div>
                                </div>

                                @if (hasPrediction && prediction is not null)
                                {
                                    <div class="fixture-prob-mini" role="img" aria-label="@ProbabilityLabel(prediction)">
                                        <span class="fixture-prob-segment home" style="@SegmentStyle(prediction.BestPrediction.Outcome.HomeWin)"></span>
                                        <span class="fixture-prob-segment draw" style="@SegmentStyle(prediction.BestPrediction.Outcome.Draw)"></span>
                                        <span class="fixture-prob-segment away" style="@SegmentStyle(prediction.BestPrediction.Outcome.AwayWin)"></span>
                                    </div>
                                    <div class="fixture-prob-labels">
                                        <span>@prediction.BestPrediction.Outcome.HomeWin.ToString("P0")</span>
                                        <span>@prediction.BestPrediction.Outcome.Draw.ToString("P0")</span>
                                        <span>@prediction.BestPrediction.Outcome.AwayWin.ToString("P0")</span>
                                    </div>
                                }
                                else if (hasError)
                                {
                                    <MudTooltip Text="@predictionError">
                                        <MudText Typo="Typo.caption" Color="Color.Warning">Predicción no disponible</MudText>
                                    </MudTooltip>
                                }
                                else
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Pendiente de predicción</MudText>
                                }
                            </div>
                        }
                    </div>
                </MudPaper>
            }
        </div>
    }

    </MudTabPanel>

    <MudTabPanel Text="Grupos y llave" Icon="@Icons.Material.Filled.EmojiEvents">
        <MudStack Spacing="3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="action-row">
                <BusyButton Text="Calcular cuadro"
                            BusyText="Calculando"
                            IsBusy="_projecting"
                            Disabled="@(!_loaded)"
                            Icon="@Icons.Material.Filled.AccountTree"
                            OnClick="BuildBracket" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Cuadro más probable según los resultados cargados y las predicciones del modelo.</MudText>
            </MudStack>

            @if (!string.IsNullOrWhiteSpace(_projectionError))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_projectionError</MudAlert>
            }

            @if (_projecting && _projection is null)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
            }
            else if (_projection is null)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">Tocá «Calcular cuadro» para ver el orden de cada grupo, los clasificados y todo el mata-mata hasta el campeón.</MudAlert>
            }
            else
            {
                <MudPaper Class="surface-card champion-banner" Elevation="0">
                    <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Size="Size.Large" />
                    <div>
                        <MudText Typo="Typo.overline" Color="Color.Secondary">Campeón proyectado</MudText>
                        <MudText Typo="Typo.h5"><TeamLabel TeamId="@_projection.ChampionTeamId" Name="@Name(_projection.ChampionTeamId)" /></MudText>
                    </div>
                </MudPaper>

                <MudText Typo="Typo.h5">Grupos</MudText>
                <div class="standings-board">
                    @foreach (var group in _projection.Groups)
                    {
                        <MudPaper Class="surface-card" Elevation="0">
                            <MudText Typo="Typo.h6">Grupo @group.Name</MudText>
                            <table class="standings-table">
                                <thead>
                                    <tr><th>#</th><th>Equipo</th><th>Pts</th><th>DG</th><th>GF</th><th>Estado</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var s in group.Standings)
                                    {
                                        <tr class="@StandingRowClass(s.Qualification)">
                                            <td class="pos">@s.Position</td>
                                            <td><TeamLabel TeamId="@s.TeamId" Name="@Name(s.TeamId)" Compact="true" /></td>
                                            <td class="num">@s.Points</td>
                                            <td class="num">@(s.GoalDiff > 0 ? $"+{s.GoalDiff}" : s.GoalDiff.ToString())</td>
                                            <td class="num">@s.GoalsFor</td>
                                            <td>
                                                @switch (s.Qualification)
                                                {
                                                    case QualificationKind.Winner:
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">1° · clasifica</MudChip>
                                                        break;
                                                    case QualificationKind.RunnerUp:
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">2° · clasifica</MudChip>
                                                        break;
                                                    case QualificationKind.ThirdQualified:
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">3° · mejor tercero</MudChip>
                                                        break;
                                                    case QualificationKind.ThirdOut:
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">3° · eliminado</MudChip>
                                                        break;
                                                    default:
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Text">Eliminado</MudChip>
                                                        break;
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </MudPaper>
                    }
                </div>

                <MudText Typo="Typo.h5">Mata-mata</MudText>
                <div class="bracket-symmetric">
                    <div class="bracket-side">
                        @for (var col = 0; col < LeftStages.Length; col++)
                        {
                            <div class="bracket-column">
                                <div class="bracket-stage-title">@LeftTitles[col]</div>
                                @foreach (var id in LeftStages[col])
                                {
                                    <BracketTie Tie="@TieById(id)" Name="Name" />
                                }
                            </div>
                        }
                    </div>

                    <div class="bracket-column bracket-center">
                        <div class="bracket-stage-title">Final</div>
                        <BracketTie Tie="@TieById(FinalTieId)" Name="Name" />
                        <div class="bracket-champion">
                            <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" />
                            <TeamLabel TeamId="@_projection.ChampionTeamId" Name="@Name(_projection.ChampionTeamId)" Compact="true" />
                        </div>
                    </div>

                    <div class="bracket-side">
                        @for (var col = 0; col < RightStages.Length; col++)
                        {
                            <div class="bracket-column">
                                <div class="bracket-stage-title">@RightTitles[col]</div>
                                @foreach (var id in RightStages[col])
                                {
                                    <BracketTie Tie="@TieById(id)" Name="Name" />
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </MudStack>
    </MudTabPanel>
    </MudTabs>
</MudStack>

@code {
    private List<Fixture> _fixtures = [];
    private Dictionary<string, string> _names = [];
    private Dictionary<string, MatchPredictionResult> _predictions = new(StringComparer.Ordinal);
    private Dictionary<string, string> _predictionErrors = new(StringComparer.Ordinal);
    private IReadOnlyList<FullFixtureSnapshotSummary> _fullFixtureSnapshots = [];
    private bool _loaded;
    private bool _snapshotsLoaded;
    private bool _predicting;
    private bool _saving;
    private bool _loadingSnapshot;
    private int _savedCount;
    private int _selectedFullFixtureSnapshotId;
    private int? _activeFullFixtureSnapshotId;
    private DateTimeOffset? _predictedAt;
    private string _error = "";
    private DeterministicProjection? _projection;
    private bool _projecting;
    private string _projectionError = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadFixtures();
        _names = await Db.Teams.AsNoTracking().ToDictionaryAsync(t => t.Id, t => t.Name);
        _loaded = true;
        await RefreshFullFixtureSnapshots();

        var latest = _fullFixtureSnapshots.FirstOrDefault(snapshot => snapshot.IsValid);
        if (latest is not null)
            await LoadFullFixtureSnapshot(latest, showToast: false);
    }

    private async Task PredictAll()
    {
        if (_fixtures.Count == 0)
            return;

        _predicting = true;
        _error = "";
        _savedCount = 0;
        _activeFullFixtureSnapshotId = null;
        _selectedFullFixtureSnapshotId = 0;
        _predictedAt = null;
        _predictions.Clear();
        _predictionErrors.Clear();

        try
        {
            var results = await Predictor.PredictFixturesAsync(OrderedFixtures(_fixtures));
            _predictions = results.ToDictionary(result => result.Fixture.Id, StringComparer.Ordinal);
            _predictedAt = DateTimeOffset.Now;
            Snackbar.Add($"Fixture completo predicho: {_predictions.Count} partidos.", Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add("No se pudo completar la predicción masiva.", Severity.Error);
            await PredictIndividually();
        }
        finally
        {
            _predicting = false;
        }
    }

    private async Task PredictIndividually()
    {
        foreach (var fixture in OrderedFixtures(_fixtures))
        {
            try
            {
                var result = await Predictor.PredictAsync(fixture);
                _predictions[fixture.Id] = result;
            }
            catch (Exception ex)
            {
                _predictionErrors[fixture.Id] = ex.Message;
            }
        }

        if (_predictions.Count > 0)
        {
            _predictedAt = DateTimeOffset.Now;
            Snackbar.Add($"Predicción parcial lista: {_predictions.Count} partidos.", Severity.Warning);
        }
    }

    private async Task SaveAll()
    {
        if (!CanSaveFullFixture)
        {
            Snackbar.Add("El fixture completo solo se puede guardar cuando todos los partidos tienen predicción.", Severity.Warning);
            return;
        }

        _saving = true;
        _error = "";
        try
        {
            var snapshot = await Snapshots.SaveFullFixtureAsync(OrderedPredictionResults().Select(result => result.BestPrediction));
            _savedCount = _predictions.Count;
            _activeFullFixtureSnapshotId = snapshot.Id;
            await RefreshFullFixtureSnapshots();
            _selectedFullFixtureSnapshotId = snapshot.Id;
            Snackbar.Add($"{_savedCount} predicciones guardadas como fixture completo.", Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add("No se pudieron guardar los snapshots.", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task RefreshFullFixtureSnapshots()
    {
        _snapshotsLoaded = false;
        try
        {
            _fullFixtureSnapshots = await Snapshots.FullFixtureSnapshotsAsync();
            if (_selectedFullFixtureSnapshotId == 0 && _fullFixtureSnapshots.FirstOrDefault(snapshot => snapshot.IsValid) is { } latest)
                _selectedFullFixtureSnapshotId = latest.Id;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add("No se pudieron cargar los snapshots de fixture completo.", Severity.Error);
        }
        finally
        {
            _snapshotsLoaded = true;
        }
    }

    private async Task LoadSelectedFullFixtureSnapshot()
    {
        var snapshot = _fullFixtureSnapshots.FirstOrDefault(s => s.Id == _selectedFullFixtureSnapshotId);
        if (snapshot is null)
            return;

        await LoadFullFixtureSnapshot(snapshot, showToast: true);
    }

    private async Task LoadFullFixtureSnapshot(FullFixtureSnapshotSummary snapshot, bool showToast)
    {
        if (!snapshot.IsValid)
        {
            Snackbar.Add(snapshot.Error ?? "El snapshot no está disponible.", Severity.Warning);
            return;
        }

        _loadingSnapshot = true;
        _error = "";
        try
        {
            var result = await Snapshots.LoadFullFixtureSnapshotAsync(snapshot.Id);
            if (!result.IsValid)
            {
                _error = result.Error ?? "No se pudo leer el snapshot.";
                Snackbar.Add(_error, Severity.Error);
                return;
            }

            _predictions = result.Predictions.ToDictionary(prediction => prediction.Fixture.Id, StringComparer.Ordinal);
            _predictionErrors.Clear();
            _savedCount = _predictions.Count;
            _predictedAt = snapshot.CreatedAt.ToLocalTime();
            _activeFullFixtureSnapshotId = snapshot.Id;
            _selectedFullFixtureSnapshotId = snapshot.Id;
            if (showToast)
                Snackbar.Add("Snapshot de fixture completo cargado.", Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add("No se pudo cargar el snapshot de fixture completo.", Severity.Error);
        }
        finally
        {
            _loadingSnapshot = false;
        }
    }

    private async Task LoadFixtures() =>
        _fixtures = await Db.Fixtures.AsNoTracking().ToListAsync();

    private IEnumerable<IGrouping<string, Fixture>> GroupedFixtures() =>
        _fixtures.GroupBy(fixture => fixture.Group).OrderBy(group => group.Key);

    private IEnumerable<Fixture> OrderedFixtures(IEnumerable<Fixture> fixtures) =>
        fixtures
            .OrderBy(fixture => fixture.KickoffUtc ?? DateTimeOffset.MaxValue)
            .ThenBy(fixture => fixture.Group)
            .ThenBy(fixture => Name(fixture.HomeTeamId))
            .ThenBy(fixture => Name(fixture.AwayTeamId));

    private IEnumerable<MatchPredictionResult> OrderedPredictionResults() =>
        OrderedFixtures(_fixtures)
            .Where(fixture => _predictions.ContainsKey(fixture.Id))
            .Select(fixture => _predictions[fixture.Id]);

    private bool CanSaveFullFixture =>
        _loaded &&
        _fixtures.Count > 0 &&
        _predictions.Count == _fixtures.Count &&
        _savedCount == 0 &&
        _activeFullFixtureSnapshotId is null;

    private string Name(string id) => _names.TryGetValue(id, out var name) ? name : id;

    private static string CardStateClass(Fixture fixture, bool hasPrediction)
    {
        if (fixture.IsPlayed && fixture.HomeGoals.HasValue && fixture.AwayGoals.HasValue)
            return "is-played";

        return hasPrediction ? "is-predicted" : "";
    }

    private async Task BuildBracket()
    {
        _projecting = true;
        _projectionError = "";
        try
        {
            _projection = await Sim.ProjectMostLikelyAsync();
        }
        catch (Exception ex)
        {
            _projectionError = ex.Message;
            Snackbar.Add("No se pudo calcular el cuadro del torneo.", Severity.Error);
        }
        finally
        {
            _projecting = false;
        }
    }

    // Cuadro oficial 2026 dividido para el render simetrico: mitad izquierda y mitad derecha
    // convergen a la final central. El orden vertical de cada columna respeta el arbol del bracket
    // (cada cruce queda entre los dos cruces que lo alimentan).
    private const int FinalTieId = 104;

    private static readonly int[][] LeftStages =
    [
        [74, 77, 73, 75, 83, 84, 81, 82], // 16avos
        [89, 90, 93, 94],                 // Octavos
        [97, 98],                         // Cuartos
        [101]                             // Semis
    ];

    private static readonly string[] LeftTitles = ["16avos", "Octavos", "Cuartos", "Semis"];

    private static readonly int[][] RightStages =
    [
        [102],                            // Semis
        [99, 100],                        // Cuartos
        [91, 92, 95, 96],                 // Octavos
        [76, 78, 79, 80, 86, 88, 85, 87]  // 16avos
    ];

    private static readonly string[] RightTitles = ["Semis", "Cuartos", "Octavos", "16avos"];

    private DeterministicTie TieById(int id) => _projection!.Knockout.First(t => t.Id == id);

    private static string StandingRowClass(QualificationKind qualification) => qualification switch
    {
        QualificationKind.Winner => "qualified-direct",
        QualificationKind.RunnerUp => "qualified-direct",
        QualificationKind.ThirdQualified => "qualified-third",
        _ => "eliminated"
    };

    private string StatusText => _predictions.Count switch
    {
        > 0 when _activeFullFixtureSnapshotId is not null && _predictedAt is not null => $"{_predictions.Count} predicciones cargadas {_predictedAt.Value:g}",
        > 0 when _savedCount > 0 => $"{_predictions.Count} predicciones | fixture completo guardado",
        > 0 when _predictedAt is not null => $"{_predictions.Count} predicciones generadas {_predictedAt.Value:t}",
        _ when _loaded => $"{_fixtures.Count} partidos de grupo",
        _ => "Cargando fixture"
    };

    private string DateText(Fixture fixture)
    {
        if (fixture.KickoffUtc is null)
            return "Fecha pendiente";

        var local = fixture.KickoffUtc.Value.ToLocalTime();
        return string.IsNullOrWhiteSpace(fixture.Venue)
            ? local.ToString("dd MMM HH:mm")
            : $"{local:dd MMM HH:mm} · {fixture.Venue}";
    }

    private static string ScoreText(Fixture fixture, MatchPredictionResult? prediction)
    {
        if (fixture.IsPlayed && fixture.HomeGoals.HasValue && fixture.AwayGoals.HasValue)
            return $"{fixture.HomeGoals}-{fixture.AwayGoals}";

        if (prediction?.BestPrediction.MostLikelyScore is { } score)
            return $"{score.Home}-{score.Away}";

        return prediction?.BestPrediction.Outcome.TopPick switch
        {
            "Home" => "1",
            "Draw" => "X",
            "Away" => "2",
            _ => "-"
        };
    }

    private static string SegmentStyle(double value) => $"width:{Math.Max(value * 100, 0):0.###}%";

    private static string ProbabilityLabel(MatchPredictionResult prediction) =>
        $"{prediction.HomeTeamName} {prediction.BestPrediction.Outcome.HomeWin:P0}, empate {prediction.BestPrediction.Outcome.Draw:P0}, {prediction.AwayTeamName} {prediction.BestPrediction.Outcome.AwayWin:P0}";

    private static string FullFixtureSnapshotText(FullFixtureSnapshotSummary snapshot)
    {
        var status = snapshot.IsValid ? $"{snapshot.FixtureCount} partidos" : "no disponible";
        return $"{snapshot.CreatedAt.ToLocalTime():g} · {status}";
    }
}
